<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="armv7">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import armv7 urdf file -->
    <xacro:include filename="$(find armv7)/urdf/armv7.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="armv7.ros2_control.xacro" />


    <xacro:armv7_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
