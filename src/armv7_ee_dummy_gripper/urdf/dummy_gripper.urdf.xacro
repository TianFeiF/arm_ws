<?xml version="1.0"?>
<!--
  Dummy two-finger parallel gripper, drawn from box primitives. Use as a
  starting template for real grippers (RobotIQ 2F-85, OnRobot RG-2, ...).

  Usage:

      <xacro:include filename="$(find armv7_ee_dummy_gripper)/urdf/dummy_gripper.urdf.xacro" />
      <xacro:armv7_ee parent="link7" />

  Adds: ee_base, ee_finger_left, ee_finger_right + 3 joints. TCP frame is `ee_tcp`.

  Replace the box meshes with your real gripper's STL/dae, and update the
  joint limits / link masses to match your hardware.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="ee_base_size"   value="0.08 0.08 0.04" />     <!-- m -->
  <xacro:property name="ee_base_z"      value="0.02" />               <!-- base offset from parent -->
  <xacro:property name="finger_size"    value="0.015 0.060 0.06" />
  <xacro:property name="finger_open"    value="0.035" />              <!-- half-stroke open -->
  <xacro:property name="finger_closed"  value="0.005" />              <!-- half-stroke closed -->
  <xacro:property name="ee_tcp_z"       value="0.10" />               <!-- TCP offset from base origin -->

  <xacro:macro name="armv7_ee" params="parent">

    <!-- mounting plate -->
    <link name="ee_base">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry><box size="${ee_base_size}" /></geometry>
        <material name="ee_grey"><color rgba="0.5 0.5 0.5 1.0" /></material>
      </visual>
      <collision>
        <geometry><box size="${ee_base_size}" /></geometry>
      </collision>
      <inertial>
        <mass value="0.3" />
        <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005" />
      </inertial>
    </link>

    <joint name="ee_mount_joint" type="fixed">
      <parent link="${parent}" />
      <child  link="ee_base" />
      <origin xyz="0 0 ${ee_base_z}" rpy="0 0 0" />
    </joint>

    <!-- left finger (prismatic along +Y) -->
    <link name="ee_finger_left">
      <visual>
        <origin xyz="0 0 0.03" rpy="0 0 0" />
        <geometry><box size="${finger_size}" /></geometry>
        <material name="ee_grey" />
      </visual>
      <collision>
        <origin xyz="0 0 0.03" rpy="0 0 0" />
        <geometry><box size="${finger_size}" /></geometry>
      </collision>
      <inertial>
        <mass value="0.05" />
        <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
      </inertial>
    </link>

    <joint name="ee_finger_left_joint" type="prismatic">
      <parent link="ee_base" />
      <child  link="ee_finger_left" />
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <axis xyz="0 1 0" />
      <limit lower="${finger_closed}"
             upper="${finger_open}"
             effort="20.0"
             velocity="0.1" />
      <dynamics damping="0.5" friction="0.0" />
    </joint>

    <!-- right finger (mirrored, mimics left) -->
    <link name="ee_finger_right">
      <visual>
        <origin xyz="0 0 0.03" rpy="0 0 0" />
        <geometry><box size="${finger_size}" /></geometry>
        <material name="ee_grey" />
      </visual>
      <collision>
        <origin xyz="0 0 0.03" rpy="0 0 0" />
        <geometry><box size="${finger_size}" /></geometry>
      </collision>
      <inertial>
        <mass value="0.05" />
        <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
      </inertial>
    </link>

    <joint name="ee_finger_right_joint" type="prismatic">
      <parent link="ee_base" />
      <child  link="ee_finger_right" />
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <axis xyz="0 -1 0" />
      <limit lower="${finger_closed}"
             upper="${finger_open}"
             effort="20.0"
             velocity="0.1" />
      <mimic joint="ee_finger_left_joint" multiplier="1.0" offset="0.0" />
      <dynamics damping="0.5" friction="0.0" />
    </joint>

    <!-- TCP frame (between the fingertips) -->
    <link name="ee_tcp" />
    <joint name="ee_tcp_joint" type="fixed">
      <parent link="ee_base" />
      <child  link="ee_tcp" />
      <origin xyz="0 0 ${ee_tcp_z}" rpy="0 0 0" />
    </joint>

  </xacro:macro>

</robot>
